# Copy this file to .env on cPanel (api.aljaroshi.com folder)
# Fill in your real values — DO NOT commit .env to git

# MySQL — get from cPanel > MySQL Databases
# Format: mysql://DB_USER:DB_PASSWORD@localhost:3306/DB_NAME
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:3306/YOUR_DB_NAME"

# Secret for login tokens — use a long random string (min 32 chars)
JWT_SECRET="change-this-to-a-long-random-secret-key"

# Node.js app port (must match cPanel Node.js app port, usually 5000)
PORT=5000

# Frontend URL for CORS and invite links
FRONTEND_URL="https://crm.aljaroshi.com"

# Production mode
NODE_ENV=production
