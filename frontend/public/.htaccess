<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. Handle API requests - ensure they are NOT rewritten to index.html
  # This allows the Node.js application to handle these routes
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^ - [L]

  # 2. SPA Routing - redirect all other non-file requests to index.html
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>
