generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ================== ENUMS ==================
enum Role {
  ADMIN
  CALL_CENTER
  TECHNICIAN
  WORKSHOP_MANAGER
}

enum JobStatus {
  New
  Assigned
  InProgress
  PendingApproval
  Completed
  Cancelled
  InspectionCompleted
  PickedForWorkshop
  Reopened
  Complaint
  Deleted
}

enum WorkshopStatus {
  Received
  WorkStarted
  WaitingForParts
  WaitingForApproval
  Ready
  Delivered
  Cancelled
}

// ================== MODELS ==================
model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?  @unique
  phone         String   @unique
  password_hash String
  plain_password String? // Added for admin visibility as requested
  role          Role
  team_id       Int?
  team          Team?    @relation(fields: [team_id], references: [id])
  is_active     Boolean  @default(true)
  
  // Profile Fields
  profile_picture String?
  location_name   String?
  lat             Float?
  lng             Float?
  specialization  String?
  address         String?

  totp_secret     String?
  totp_enabled    Boolean  @default(false)

  created_at    DateTime @default(now())

  assigned_jobs Lead[]   @relation("AssignedTo")
  created_leads Lead[]   @relation("CreatedBy")   // Changed name
  expenses      Expense[]
  posts         Post[]

  @@map("users")
}

model Post {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  content     String?  @db.Text
  visibility  String   @default("Public")
  location    String?
  hashtags    String?
  product_tag String?
  media       Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("posts")
}

model Team {
  id            Int      @id @default(autoincrement())
  name          String
  contact       String?
  payment_model Json?    // Better for flexibility
  created_at    DateTime @default(now())

  users         User[]
  leads         Lead[]
  @@map("teams")
}

model Customer {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String   @unique
  area            String?
  exact_address   String?  @db.Text
  google_map_link String?  @db.Text
  created_at      DateTime @default(now())

  leads           Lead[]
  @@map("customers")
}

model Lead {
  id                Int      @id @default(autoincrement())
  lead_id           String   @unique   // e.g. 03MAY26001

  customer_id       Int
  customer          Customer @relation(fields: [customer_id], references: [id])

  product_type      String
  problem_details   String?  @db.Text
  product_image     String?  @db.LongText
  house_image       String?  @db.LongText
  item_pictures     Json?
  exact_address     String?  @db.Text

  status            JobStatus @default(New)
  is_warranty_claim Boolean   @default(false)

  assigned_to       Int?
  technician        User?    @relation("AssignedTo", fields: [assigned_to], references: [id])

  assigned_by       Int?
  assigned_by_user  User?    @relation("CreatedBy", fields: [assigned_by], references: [id])  // Fixed

  assigned_at       DateTime?
  visit_date        DateTime?

  actual_problem    String?  @db.Text
  repair_details    String?  @db.Text
  total_amount      Decimal? @db.Decimal(10, 2)
  collected_amount  Decimal? @db.Decimal(10, 2) @default(0)
  agreed_amount     Decimal? @db.Decimal(10, 2)
  payment_confirmed Boolean  @default(false)
  pending_outcome   String?
  rejection_note    String?  @db.Text
  voice_note        String?  @db.LongText
  lat               Float?
  lng               Float?

  warranty_months   Int      @default(1)
  warranty_start    DateTime?
  warranty_end      DateTime?

  team_id           Int?
  team              Team?    @relation(fields: [team_id], references: [id])

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  history           JobHistory[]
  workshop_job      WorkshopJob?
  products          LeadProduct[]

  @@map("leads")
}

model LeadProduct {
  id              Int      @id @default(autoincrement())
  lead_id         Int
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  product_type    String
  problem_details String?  @db.Text
  sort_order      Int      @default(0)
  created_at      DateTime @default(now())

  @@index([lead_id])
  @@map("lead_products")
}

model JobHistory {
  id            Int       @id @default(autoincrement())
  lead_id       Int
  lead          Lead      @relation(fields: [lead_id], references: [id])
  action        String
  performed_by  Int?
  old_status    JobStatus?
  new_status    JobStatus?
  notes         String?
  timestamp     DateTime  @default(now())

  @@map("job_history")
}

model WorkshopJob {
  id                 Int           @id @default(autoincrement())
  lead_id            Int           @unique
  lead               Lead          @relation(fields: [lead_id], references: [id])

  received_date      DateTime      @default(now())
  received_by        Int?
  promised_delivery  DateTime?
  priority           String        @default("Normal")
  status             WorkshopStatus @default(Received)
  current_day_count  Int           @default(0)
  notes              String?       @db.Text
  agreed_parts       String?       @db.Text
  additional_parts   String?       @db.Text
  parts_media        Json?

  delivered_at           DateTime?
  delivered_by           Int?
  delivery_assigned_to   Int?
  delivery_assigned_at   DateTime?

  @@map("workshop_jobs")
}

// New Model (Phase 2 ke liye zaroori)
model Expense {
  id            Int       @id @default(autoincrement())
  user_id       Int
  user          User      @relation(fields: [user_id], references: [id])
  lead_id       Int?
  amount        Decimal   @db.Decimal(10, 2)
  category      String    // Petrol, Food, Parts, Transport, Other, Salary, Rent, Spare parts, Food, Marketing, Vehicle, Tools, etc.
  description   String?
  date          DateTime  @default(now())

  is_recurring  Boolean   @default(false)
  frequency     String?   // "Monthly", "Weekly", "Daily"
  due_day       Int?      // Day of month/week when it is due
  last_paid     DateTime?
  next_due      DateTime?
  custom_data   Json?     // Stores dynamic custom fields data

  @@map("expenses")
}

model InviteToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  role       Role
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("invite_tokens")
}

model Area {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  lat         Float?
  lng         Float?
  created_at  DateTime @default(now())

  @@map("areas")
}

model TechnicianSettlement {
  id            Int      @id @default(autoincrement())
  technician_id Int
  amount        Decimal  @db.Decimal(10, 2)
  description   String?
  lead_id       Int?
  is_received   Boolean  @default(false)
  received_at   DateTime?
  received_by   Int?
  created_at    DateTime @default(now())

  @@map("technician_settlements")
}

model CustomField {
  id          Int      @id @default(autoincrement())
  module      String   // e.g. "RecurringPayment"
  field_name  String
  field_type  String   // e.g. "Text", "Number", "Date", "Dropdown", "File"
  options     Json?    // For Dropdown options (array of strings)
  is_required Boolean  @default(false)
  created_at  DateTime @default(now())
  
  @@map("custom_fields")
}

model SystemLog {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  user_name   String?
  action_type String   // CREATE, UPDATE, DELETE, RESTORE
  module      String   // Finance, Lead, etc.
  old_value   Json?
  new_value   Json?
  panel       String?  // Admin Panel, etc.
  created_at  DateTime @default(now())

  @@map("system_logs")
}

model Trash {
  id           Int      @id @default(autoincrement())
  model_name   String   // Expense, Lead, etc.
  record_id    Int
  data         Json     // The complete deleted record
  deleted_by   Int?
  deleted_at   DateTime @default(now())

  @@map("trash")
}

model PasswordResetOtp {
  id         Int      @id @default(autoincrement())
  email      String
  otp        String
  expires_at DateTime
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("password_reset_otps")
}